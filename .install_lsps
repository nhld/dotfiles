#!/bin/bash

set -euo pipefail

LOG_FILE="$HOME/dotfiles-lsps.log"
exec > >(tee -a "$LOG_FILE")
exec 2>&1

echo "=== Language Server Installation Started: $(date) ==="
echo "Log file: $LOG_FILE"

if ! command -v npm >/dev/null 2>&1; then
    echo "❌ Error: npm is not installed or not in PATH"
    exit 1
fi

echo "📦 Using npm: $(npm --version)"
echo "📦 Using node: $(node --version)"

declare -a npm_lsps=(
    "@typescript/native-preview"
    "stylelint-lsp"
    "vscode-langservers-extracted"
    "bash-language-server"
)

installed_count=0
failed_count=0

echo "🚀 Installing npm language servers..."

for lsp in "${npm_lsps[@]}"; do
    echo "📦 Installing $lsp..."
    if npm install -g "$lsp"; then
        echo "✅ Successfully installed: $lsp"
        installed_count=$((installed_count + 1))
    else
        echo "❌ Failed to install: $lsp"
        failed_count=$((failed_count + 1))
    fi
done

echo ""
echo "🚀 Installing Go language servers..."

if command -v go >/dev/null 2>&1; then
    if go install golang.org/x/tools/gopls@latest; then
        echo "✅ Successfully installed: gopls"
        installed_count=$((installed_count + 1))
    else
        echo "❌ Failed to install: gopls"
        failed_count=$((failed_count + 1))
    fi
else
    echo "⚠️  go not found, skipping gopls"
fi

echo ""
echo "📋 Additional tools requiring manual installation:"
echo "  • lua-language-server: brew install lua-language-server"
echo "  • ruby-lsp:            brew install ruby-lsp"
echo "  • clangd:              brew install llvm"
echo "  • dprint:              brew install dprint"

echo ""
echo "📊 Installation Summary:"
echo "  ✅ Installed: $installed_count language servers"
echo "  ❌ Failed: $failed_count language servers"

echo "=== Language Server Installation Finished: $(date) ==="

if [ $failed_count -eq 0 ]; then
    echo "✅ All language servers installed successfully"
    exit 0
else
    echo "⚠️  Some language servers failed to install"
    exit 1
fi
